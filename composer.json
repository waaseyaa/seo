{
    "name": "waaseyaa/seo",
    "description": "SEO building blocks for Waaseyaa (sitemap, robots.txt, meta tags, JSON-LD, Twig helpers)",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.4",
        "twig/twig": "^3.0",
        "waaseyaa/entity": "^0.1.0-alpha.150",
        "waaseyaa/foundation": "^0.1.0-alpha.150"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Seo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Seo\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        },
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\Seo\\SeoServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    }
}
